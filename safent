#!/bin/sh
# safent - control the local Safent container from your terminal.
#
#   safent            open Safent in the browser (starts it if stopped)
#   safent stop       stop Safent
#   safent start      start Safent without opening the browser
#   safent restart    restart Safent
#   safent update     pull the latest image and recreate (keeps your config)
#   safent status     is it running? on which port?
#   safent logs       follow the container journal
#
# ASCII-only + POSIX sh on purpose (portable across macOS bash 3.2 / dash / zsh-as-sh).
# The model, Composio, Brave, agents and skills are all configured IN THE UI.
set -e

# Monotonic CLI revision. `safent update` self-updates this script from CLI_URL
# when the published revision is HIGHER (never downgrades). Bump on every CLI
# change or the fix will not reach installed machines.
_CLI_REV=6

# ONE runtime image for both community and associate (paired) operation. The
# image carries no edition-specific code: pairing state (the .enterprise marker +
# is_associated()) is what activates associate behavior at runtime, so the same
# image runs both roles. There is intentionally no separate "enterprise" image.
IMAGE="${SAFENT_IMAGE:-ghcr.io/devwspito/safent:latest}"
NAME="${SAFENT_NAME:-safent}"
PORT_PIN="${SAFENT_PORT:-}"
# Enterprise cloud the instance pairs/syncs against. Empty for community edition.
# Forwarded into the container at run (-e) AND to the pair handshake (--cloud) so
# the personalized curl one-liner (SAFENT_CLOUD_ENDPOINT=... safent pair) reaches
# the tenant's cloud instead of the default https://cloud.safent.run.
CLOUD_ENDPOINT="${SAFENT_CLOUD_ENDPOINT:-}"
# Named volume that holds the persistent state (config, identity, skills, memory).
# Override SAFENT_DATA_VOLUME to run more than one isolated instance on one host.
DATA_VOLUME="${SAFENT_DATA_VOLUME:-safent-data}"
SECCOMP_URL="${SAFENT_SECCOMP_URL:-https://raw.githubusercontent.com/devwspito/safent-runtime/main/ops/container/seccomp/safent.json}"
SECCOMP_DIR="${HOME:-/tmp}/.safent"
SECCOMP="$SECCOMP_DIR/safent-seccomp.json"
# Where `safent update` fetches the newest CLI from (same source the installer uses).
CLI_URL="${SAFENT_CLI_URL:-https://raw.githubusercontent.com/devwspito/safent-runtime/main/safent}"

# GUI-launched contexts hand this script a MINIMAL PATH: a launchd LaunchAgent (the
# `safent agent` update watcher) and a Finder-launched .app both run with roughly
# /usr/bin:/bin:/usr/sbin:/sbin — which does NOT include /opt/homebrew/bin, where podman
# lives. Without this, `command -v podman` below finds nothing, RT ends up empty, and the
# UI-triggered update/uninstall agent SILENTLY dies (every `"$RT" exec` is a no-op, so the
# marker is never consumed and the UI hangs forever on "Actualizando…"). Prepend the
# well-known engine install dirs so RT resolves no matter how we were launched.
for _d in /opt/homebrew/bin /usr/local/bin /opt/podman/bin "${HOME:-}/.local/bin"; do
  [ -n "$_d" ] && [ -d "$_d" ] || continue
  case ":$PATH:" in *":$_d:"*) ;; *) PATH="$_d:$PATH" ;; esac
done
export PATH

RT="$(command -v podman 2>/dev/null || command -v docker 2>/dev/null || true)"
[ -n "$RT" ] || { echo "[x] You need podman or docker.  ->  https://podman.io/get-started" >&2; exit 1; }
RTN="$(basename "$RT")"
OS="$(uname -s 2>/dev/null || echo unknown)"

# ---- helpers ----------------------------------------------------------------

_exists()  { "$RT" inspect "$NAME" >/dev/null 2>&1; }
_running() { [ "$("$RT" inspect -f '{{.State.Running}}' "$NAME" 2>/dev/null || echo false)" = true ]; }

# Pairing marker — written to the persistent volume on pair, removed on unpair.
# Stored inside the volume so it survives container recreates. config-sync's
# systemd ConditionPathExists keys off this marker, so the launcher keeps writing
# it; it no longer selects a different image (there is only one).
_ENTERPRISE_MARKER="/var/lib/hermes/instance/.enterprise"

# Single image for every role. Kept as a function so existing call sites are
# untouched and a future per-instance image override stays a one-line change.
_image() {
  echo "$IMAGE"
}

# macOS: the cage runs inside a podman machine, which MUST be rootful.
_ensure_machine() {
  [ "$RTN" = podman ] && [ "$OS" = Darwin ] || return 0
  name="$(podman machine list -q 2>/dev/null | head -1)"
  if [ -z "$name" ]; then
    echo "[*] No podman machine - creating a rootful one (first time only, takes a bit)..."
    podman machine init --rootful --cpus 4 --memory 8192 --disk-size 60 \
      && podman machine start \
      || { echo "[x] Could not create/start the podman machine."; exit 1; }
    name="$(podman machine list -q 2>/dev/null | head -1)"
  fi
  rootful="$(podman machine inspect "$name" --format '{{.Rootful}}' 2>/dev/null | head -1)"
  if [ "$rootful" != "true" ]; then
    echo "[x] The podman machine '$name' is rootless; the cage needs rootful. Convert it:"
    echo "    podman machine stop '$name' && podman machine set --rootful '$name' && podman machine start '$name'"
    exit 1
  fi
  podman info >/dev/null 2>&1 || podman machine start "$name" >/dev/null 2>&1 || true
}

# seccomp profile under $HOME (on macOS the VM mounts $HOME but NOT /tmp).
_ensure_seccomp() {
  mkdir -p "$SECCOMP_DIR" 2>/dev/null || true
  # 1. Preferred: pull the profile straight out of the image — v0.8.29+ ship it baked
  #    at /usr/share/hermes/seccomp/safent.json, version-matched and with NO network.
  if "$RTN" run --rm --entrypoint cat "$(_image)" \
       /usr/share/hermes/seccomp/safent.json > "$SECCOMP.tmp" 2>/dev/null && [ -s "$SECCOMP.tmp" ]; then
    mv "$SECCOMP.tmp" "$SECCOMP"; return 0
  fi
  rm -f "$SECCOMP.tmp" 2>/dev/null || true
  # 2. Fallback: download from the repo (older images without the baked file), with
  #    retries so a transient raw.githubusercontent hiccup doesn't break the update.
  if curl -fsSL --retry 3 --retry-delay 2 "$SECCOMP_URL" -o "$SECCOMP.tmp" 2>/dev/null && [ -s "$SECCOMP.tmp" ]; then
    mv "$SECCOMP.tmp" "$SECCOMP"; return 0
  fi
  rm -f "$SECCOMP.tmp" 2>/dev/null || true
  # 3. Last resort: reuse a previously-cached profile so a transient failure never
  #    bricks an already-working install (the profile rarely changes).
  if [ -s "$SECCOMP" ]; then
    echo "[!] Using the cached seccomp profile (could not refresh from image or $SECCOMP_URL)."
    return 0
  fi
  echo "[x] Could not obtain the seccomp profile (image + $SECCOMP_URL failed, no cache)."
  echo "    Check the image pulled correctly, or export SAFENT_SECCOMP_URL to a reachable URL."
  exit 1
}

# Recreate the container with the hardened cage (loopback + min caps + seccomp).
# Uses _image() (single runtime image, paired or not).
_run() {
  _ensure_machine
  _ensure_seccomp
  _active_image="$(_image)"
  "$RT" rm -f "$NAME" >/dev/null 2>&1 || true
  if [ -n "$PORT_PIN" ]; then publish="127.0.0.1:${PORT_PIN}:7517"; else publish="127.0.0.1::7517"; fi
  "$RT" run -d --name "$NAME" --systemd=always \
    -p "$publish" \
    ${CLOUD_ENDPOINT:+-e SAFENT_CLOUD_ENDPOINT=$CLOUD_ENDPOINT} \
    --cap-add NET_ADMIN --cap-add SYS_ADMIN --cap-add AUDIT_READ \
    --security-opt seccomp="$SECCOMP" \
    --security-opt unmask=/sys/kernel/security \
    --security-opt label=disable \
    -v /sys/kernel/security:/sys/kernel/security:ro \
    -v "$DATA_VOLUME":/var/lib/hermes \
    --shm-size=1g \
    "$_active_image" >/dev/null
}

_port() {
  if [ -n "$PORT_PIN" ]; then echo "$PORT_PIN"; return; fi
  p="$("$RT" port "$NAME" 7517 2>/dev/null | head -1 | sed 's/.*:\([0-9][0-9]*\)$/\1/')"
  if [ -n "$p" ]; then echo "$p"; else echo 17517; fi
}

# Wait until the runtime is active and print the URL with the ?k= handshake.
_url() {
  secret=""
  i=0
  while [ "$i" -lt 48 ]; do
    a="$("$RT" exec "$NAME" systemctl is-active hermes-runtime 2>/dev/null || true)"
    if [ "$a" = active ]; then
      secret="$("$RT" exec "$NAME" cat /var/lib/hermes-bootstrap/bootstrap/webui-bootstrap 2>/dev/null | tr -d '\r\n' || true)"
      [ -n "$secret" ] && break
    fi
    [ "$a" = failed ] && break
    sleep 5
    i=$((i + 1))
  done
  [ -n "$secret" ] || { echo ""; return 1; }
  echo "http://localhost:$(_port)/?k=${secret}"
}

_open_browser() {
  # The desktop app (Tauri shell) shows the UI in its OWN native window, so it sets
  # SAFENT_NO_BROWSER=1 when it drives the curl bootstrap / `safent update` — do NOT
  # also pop the system browser. Terminal users (unset) still get the browser as before.
  [ -n "${SAFENT_NO_BROWSER:-}" ] && return 0
  if command -v open >/dev/null 2>&1; then open "$1" >/dev/null 2>&1 || true
  elif command -v xdg-open >/dev/null 2>&1; then xdg-open "$1" >/dev/null 2>&1 || true
  fi
}

_open_and_print() {
  echo "[*] Waiting for Safent..."
  url="$(_url)" || url=""
  if [ -n "$url" ]; then
    echo ""
    echo "  Safent is ready:"
    echo "     $url"
    echo ""
    _open_browser "$url"
  else
    echo "  [!] Safent started but I could not get the token. Check:  safent logs"
    exit 1
  fi
}

# ---- subcommands ------------------------------------------------------------

cmd_open() {
  _ensure_machine
  if _exists; then
    _running || { echo "[*] Starting Safent..."; "$RT" start "$NAME" >/dev/null 2>&1 || true; }
  else
    echo "[*] First run - downloading and starting Safent..."
    "$RT" pull "$IMAGE" >/dev/null 2>&1 || true
    _run
  fi
  _open_and_print
}

# Ensure Safent is running and print ONLY the URL (with ?k= handshake) to stdout.
# No browser, no decorative text — machine-readable for the Tauri desktop shell
# (desktop/) which loads this exact URL in a native webview. Reversible: the
# desktop shell is optional; this command is additive and harmless for CLI users.
cmd_url() {
  # Progress goes to STDERR (human-readable, streamed by the Tauri shell's install
  # animation); STDOUT carries ONLY the final URL. Diagnostics from the setup helpers
  # are redirected to stderr too, so stdout stays a clean single line.
  echo "Preparando el entorno…" >&2
  _ensure_machine >&2
  if _exists; then
    _running || { echo "Arrancando Safent…" >&2; "$RT" start "$NAME" >/dev/null 2>&1 || true; }
  else
    echo "Descargando Safent (primera vez, puede tardar unos minutos)…" >&2
    "$RT" pull "$IMAGE" >/dev/null 2>&1 || true
    echo "Arrancando Safent…" >&2
    _run >&2
  fi
  echo "Esperando a que Safent esté listo…" >&2
  url="$(_url)" || url=""
  [ -n "$url" ] || { echo "Safent arrancó pero aún no hay token — prueba: safent logs" >&2; exit 1; }
  printf '%s\n' "$url"
}

cmd_start() {
  _ensure_machine
  if _exists; then
    if _running; then echo "[ok] Safent is already running (run 'safent' to open it)."; return; fi
    "$RT" start "$NAME" >/dev/null 2>&1 || true
    echo "[ok] Safent started. Open it with:  safent"
  else
    "$RT" pull "$IMAGE" >/dev/null 2>&1 || true
    _run
    echo "[ok] Safent started. Open it with:  safent"
  fi
}

cmd_stop() {
  if _exists && _running; then
    if "$RT" stop "$NAME" >/dev/null 2>&1; then echo "[ok] Safent stopped."; else echo "[x] Could not stop it."; fi
  else
    echo "[ok] Safent was already stopped."
  fi
}

cmd_restart() { cmd_stop; cmd_open; }

# Reclaim disk used by OLD Safent images + dangling layers + the build cache. This is
# surgical and cannot lose data:
#   • It removes ONLY images of the Safent repo, and NEVER the one the current container
#     runs on (so a failed pull always leaves you on the working version).
#   • It leaves every other app's images alone.
#   • It never runs `volume prune`, so the safent-data volume (keystore / MFA / providers
#     / config / memory) is physically out of reach of this path — nothing can be lost.
# Each old version hoards ~7 GB; on a machine that filled up over time, freeing them
# BEFORE the pull is what stops "no space left on device" from wedging the update.
_reclaim_space() {
  repo="${IMAGE%:*}"                                                   # ghcr.io/devwspito/safent
  keep="$("$RT" inspect -f '{{.Image}}' "$NAME" 2>/dev/null | sed 's/^sha256://')"
  n=0
  if [ -n "$keep" ]; then
    old="$("$RT" images --no-trunc --format '{{.ID}} {{.Repository}}' 2>/dev/null \
          | awk -v r="$repo" '$2==r {print $1}' | sed 's/^sha256://' | sort -u)"
    for id in $old; do
      [ "$id" = "$keep" ] && continue                                 # never the running image
      "$RT" rmi -f "sha256:$id" >/dev/null 2>&1 && n=$((n + 1)) || true
    done
  fi
  "$RT" image prune -f   >/dev/null 2>&1 || true                       # untagged/dangling leftovers
  "$RT" builder prune -f >/dev/null 2>&1 || true                       # build cache (safe to drop)
  [ "$n" -gt 0 ] && echo "[ok] Freed space from $n old Safent image(s)."
  return 0
}

# Self-update the CLI itself before updating the image. The prune/agent fixes
# live in THIS script — the image cannot deliver them — so `safent update` keeps
# the CLI current too, without the owner ever re-running the installer. Only
# replaces when the published _CLI_REV is strictly newer (never downgrades);
# fail-soft on any error (offline, read-only install dir, repo unreachable).
_self_update() {
  [ "${SAFENT_NO_SELF_UPDATE:-0}" = "1" ] && return 0
  tmp="$(mktemp 2>/dev/null)" || return 0
  if curl -fsSL "$CLI_URL" -o "$tmp" 2>/dev/null \
     && [ -s "$tmp" ] && head -1 "$tmp" | grep -q '^#!'; then
    remote_rev="$(sed -n 's/^_CLI_REV=\([0-9][0-9]*\).*/\1/p' "$tmp" | head -1)"
    if [ -n "$remote_rev" ] && [ "$remote_rev" -gt "$_CLI_REV" ] 2>/dev/null \
       && sh -n "$tmp" 2>/dev/null; then
      if cat "$tmp" > "$0" 2>/dev/null; then
        rm -f "$tmp"
        echo "[ok] safent CLI updated (rev $_CLI_REV -> $remote_rev). Continuing..."
        SAFENT_NO_SELF_UPDATE=1 exec "$0" update
      fi
    fi
  fi
  rm -f "$tmp" 2>/dev/null || true
  return 0
}

# Make sure the UI-update watcher (`safent agent`) is installed and running.
# The UI's "Actualizar" button only drops a flag INSIDE the container; without
# this host-side watcher nothing picks it up and the UI hangs on "Updating…".
# Installing it here (not only in get-safent.sh) means one `safent update` run is
# enough to enable UI updates on machines installed before the agent existed.
_ensure_agent() {
  self="$(command -v safent 2>/dev/null || echo "$0")"
  mkdir -p "$HOME/.safent" 2>/dev/null || true
  case "$OS" in
    Darwin)
      _pl="$HOME/Library/LaunchAgents/run.safent.agent.plist"
      if [ ! -f "$_pl" ] || ! grep -q "$self" "$_pl" 2>/dev/null; then
        mkdir -p "$HOME/Library/LaunchAgents" 2>/dev/null || return 0
        cat > "$_pl" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>run.safent.agent</string>
  <key>ProgramArguments</key><array><string>$self</string><string>agent</string></array>
  <key>EnvironmentVariables</key>
  <dict><key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/opt/podman/bin:/usr/bin:/bin:/usr/sbin:/sbin</string></dict>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>$HOME/.safent/agent.log</string>
  <key>StandardErrorPath</key><string>$HOME/.safent/agent.log</string>
</dict></plist>
PLIST
        launchctl unload "$_pl" >/dev/null 2>&1 || true
        launchctl load "$_pl" >/dev/null 2>&1 \
          && echo "[ok] UI-triggered updates enabled (background agent)." || true
      fi
      ;;
    Linux)
      if command -v systemctl >/dev/null 2>&1 && systemctl --user show-environment >/dev/null 2>&1; then
        _u="$HOME/.config/systemd/user"
        if [ ! -f "$_u/safent-agent.service" ]; then
          mkdir -p "$_u" 2>/dev/null || true
          cat > "$_u/safent-agent.service" <<UNIT
[Unit]
Description=Safent UI-triggered update agent
[Service]
ExecStart=$self agent
Restart=always
RestartSec=10
[Install]
WantedBy=default.target
UNIT
          systemctl --user daemon-reload >/dev/null 2>&1 || true
          systemctl --user enable --now safent-agent.service >/dev/null 2>&1 \
            && echo "[ok] UI-triggered updates enabled (systemd --user)." || true
        fi
      fi
      ;;
  esac
  return 0
}

cmd_update() {
  _self_update
  _ensure_agent
  echo "[*] Fetching the latest Safent image..."
  _ensure_machine
  # Reclaim space BEFORE pulling so the new image has room even on a full disk. See
  # _reclaim_space: it only ever touches old Safent images / dangling layers / build
  # cache — your data volume is never in scope.
  echo "[*] Reclaiming space from previous versions (your data is untouched)..."
  _reclaim_space
  # Pull the correct image (enterprise or community) based on the current marker.
  "$RT" pull "$(_image)"
  echo "[*] Recreating the container with the new image..."
  _run   # -v safent-data keeps your config (keystore, MFA, providers)
  # The image we ran until a second ago is now unreferenced (tag moved to the new pull,
  # container recreated) → reclaim it too, same surgical path.
  _reclaim_space
  _open_and_print
}

# ---- enterprise pairing -----------------------------------------------------
# Pairing turns this SAME image into the cloud-managed associate at runtime — no
# separate image to pull. The handshake writes the association row + the
# .enterprise marker; the marker gates config-sync (ConditionPathExists), which
# then pulls and applies signed cloud policy.

cmd_pair() {
  _code="$1"
  if [ -z "$_code" ]; then
    echo "[x] Usage: safent pair <code>"; exit 1
  fi
  _ensure_machine
  # Ensure the container is running before we exec into it.
  if ! _running; then
    echo "[*] Starting Safent to complete pairing..."
    cmd_start
  fi
  # Run the pairing handshake inside the container.
  # Code is passed via stdin (not argv) to avoid exposure in process listings.
  echo "[*] Running pairing handshake..."
  printf '%s' "$_code" | "$RT" exec -i "$NAME" python3 -m hermes.instance pair --stdin ${CLOUD_ENDPOINT:+--cloud "$CLOUD_ENDPOINT"} || { echo "[x] Pairing failed."; exit 1; }
  # Write the pairing marker so config-sync's ConditionPathExists gate opens.
  "$RT" exec "$NAME" sh -c "mkdir -p /var/lib/hermes/instance && touch $_ENTERPRISE_MARKER" >/dev/null 2>&1 || true
  # Start cloud policy sync now (the unit is ConditionPathExists-gated on the
  # marker we just wrote). Best-effort — a restart would also bring it up.
  "$RT" exec "$NAME" systemctl start hermes-config-sync.service >/dev/null 2>&1 || true
  echo "[ok] Enterprise association complete.  Restart Safent to activate: safent restart"
}

cmd_unpair() {
  _ensure_machine
  if ! _running; then
    echo "[x] Safent must be running to unpair.  Start it with: safent start"; exit 1
  fi
  "$RT" exec "$NAME" python3 -m hermes.instance unpair || { echo "[x] Unpair failed."; exit 1; }
  # Remove the pairing marker so config-sync goes inert again (community mode).
  "$RT" exec "$NAME" rm -f "$_ENTERPRISE_MARKER" >/dev/null 2>&1 || true
  echo "[ok] Instance unpaired.  Restart Safent to revert to community edition: safent restart"
}

cmd_status() {
  if _exists && _running; then
    echo "[ok] Safent running at  http://localhost:$(_port)/   (open with: safent)"
  elif _exists; then
    echo "[ ] Safent is stopped.  Start it with: safent"
  else
    echo "[ ] Safent is not installed.  Install with: safent update"
  fi
}

cmd_logs() { "$RT" logs -f "$NAME"; }

# ---- background update agent (host-side; the UI-triggered update path) -------
# The container is sandboxed and CANNOT recreate itself (touching the host podman
# would defeat the cage). So "update from the UI" works like this: the UI writes an
# "update requested" marker into the data volume; THIS loop — installed once as a
# launchd agent (macOS) / systemd --user unit or nohup (Linux) by the installer —
# notices it and runs the same `safent update` (prune-before-pull + recreate). The
# user never opens a terminal. It also removes the marker so it runs exactly once
# per request. Nothing here is privileged beyond the podman the user already runs.
# In the daemon-owned instance dir (uid 880 can write there — same place as the
# pairing marker; the parent /var/lib/hermes is root:root 0755 and NOT writable by
# the daemon). The backend's POST /api/v1/system/update touches this exact path.
_UPDATE_FLAG="/var/lib/hermes/instance/.update-requested"
_UNINSTALL_FLAG="/var/lib/hermes/instance/.uninstall-requested"
cmd_agent() {
  echo "[*] Safent update agent running (watches for UI-triggered updates/uninstall)."
  while :; do
    # Uninstall wins over update — checked first; it removes everything (incl. this agent).
    if _running && "$RT" exec "$NAME" test -f "$_UNINSTALL_FLAG" 2>/dev/null; then
      echo "[*] Uninstall requested from the UI — removing Safent…"
      cmd_uninstall
      exit 0
    fi
    if _running && "$RT" exec "$NAME" test -f "$_UPDATE_FLAG" 2>/dev/null; then
      "$RT" exec "$NAME" rm -f "$_UPDATE_FLAG" 2>/dev/null || true
      echo "[*] Update requested from the UI — applying..."
      cmd_update || echo "[!] Update failed; re-request it from the UI to retry."
    fi
    sleep 20
  done
}

# Remove Safent from the machine: the container, its data volume, the seccomp cache,
# the UI-update agent, and the CLI itself. Leaves podman/docker installed (they are
# general tools you may use elsewhere). Triggerable from the UI (POST /system/uninstall
# → marker → the agent runs this) or by hand: `safent uninstall`.
cmd_uninstall() {
  echo "[*] Uninstalling Safent…"
  "$RT" rm -f "$NAME" >/dev/null 2>&1 || true
  "$RT" volume rm "$DATA_VOLUME" >/dev/null 2>&1 || true
  rm -rf "$SECCOMP_DIR" 2>/dev/null || true
  case "$OS" in
    Darwin)
      launchctl unload "$HOME/Library/LaunchAgents/run.safent.agent.plist" 2>/dev/null || true
      rm -f "$HOME/Library/LaunchAgents/run.safent.agent.plist" 2>/dev/null || true
      ;;
    Linux)
      systemctl --user disable --now safent-agent.service >/dev/null 2>&1 || true
      rm -f "$HOME/.config/systemd/user/safent-agent.service" 2>/dev/null || true
      ;;
  esac
  rm -rf "$HOME/.safent" 2>/dev/null || true
  # Remove the CLI last (safe to unlink a running script on Unix).
  rm -f /opt/homebrew/bin/safent /usr/local/bin/safent "$HOME/.local/bin/safent" "$HOME/bin/safent" 2>/dev/null || true
  echo "[ok] Safent uninstalled. (podman/docker were left installed.)"
}

usage() {
  cat <<'EOF'
safent - control your local Safent

  safent            open Safent in the browser (starts it if stopped)
  safent url        print the ready URL with ?k= handshake (starts it; no browser)
  safent stop       stop Safent
  safent start      start Safent without opening the browser
  safent restart    restart Safent
  safent update     pull the latest version and apply it (keeps your config)
  safent status     is it running? on which port?
  safent logs       follow the container journal
  safent pair <code>   associate with an enterprise tenant (same image, associate mode)
  safent unpair        remove the enterprise association (reverts to community edition)
  safent uninstall     remove Safent (container + data + CLI + agent; keeps podman/docker)
EOF
}

case "${1:-open}" in
  ""|open|abrir)               cmd_open ;;
  url)                         cmd_url ;;
  start|arranca)               cmd_start ;;
  stop|para|parar)             cmd_stop ;;
  restart|reinicia)            cmd_restart ;;
  update|actualiza|actualizar) cmd_update ;;
  agent|watch)                 cmd_agent ;;
  status|estado)               cmd_status ;;
  logs|log)                    cmd_logs ;;
  pair|vincular)               cmd_pair "${2:-}" ;;
  unpair|desvincular)          cmd_unpair ;;
  uninstall|desinstalar)       cmd_uninstall ;;
  -h|--help|help|ayuda)        usage ;;
  *) echo "Unknown command: $1"; echo; usage; exit 1 ;;
esac
