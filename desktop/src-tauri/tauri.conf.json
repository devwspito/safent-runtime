{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Safent",
  "version": "0.1.0",
  "identifier": "com.safent.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Safent",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
