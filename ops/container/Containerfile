# Lumen runtime — STANDARD container (Playwright/Ubuntu + systemd PID1).
# Replaces the bootc-OS→qcow2→VM→relay delivery. Same daemon, same units, same
# confinement — run via `podman/docker run --systemd=always -p 17517:7517`.
#
#   Build (from repo root):  podman build -f ops/container/Containerfile -t lumen:dev .
#   Run:                     podman run -d --name lumen --systemd=always \
#                              --cap-drop ALL --cap-add NET_ADMIN --cap-add SYS_ADMIN \
#                              --cap-add AUDIT_READ --security-opt no-new-privileges \
#                              --shm-size=1g -p 17517:7517 lumen:dev
#   UI:                      http://localhost:17517
#
# systemd PID1 is REQUIRED: the daemon fail-closes via _assert_confinement_active()
# which checks `systemctl is-active` of the netns/egress units. A plain entrypoint
# would force the dev-mode bypass = silent loss of the confinement moat.
FROM mcr.microsoft.com/playwright:v1.59.0-noble

# LUMEN_EDITION only writes a COSMETIC label string to /usr/share/hermes/edition
# (surfaced on /api/v1/profile, consumed by nothing). It does NOT gate any unit,
# view, capability, or security control. hermes-config-sync is enabled in BOTH
# editions (see below); the real activation is RUNTIME pairing state — the
# .enterprise marker + is_associated() — so a paired CE image runs as the
# associate. The 'enterprise' tag is therefore functionally redundant.
# There is ONE runtime image; LUMEN_EDITION defaults to "community" and only
# stamps the label. Build it:
#   podman build -f ops/container/Containerfile \
#                -t ghcr.io/devwspito/lumen:latest .
ARG LUMEN_EDITION=community

ENV DEBIAN_FRONTEND=noninteractive PIP_BREAK_SYSTEM_PACKAGES=1

# ── System packages we ADD on top of the Playwright base ─────────────────────
# Base already provides: Node 20 + npm/npx, Chromium + all its shared libs +
# fonts under /ms-playwright. We add: systemd (PID1 + the org.hermes.Runtime1
# bus the daemon owns), python 3.12, the netns/nftables moat, uv, build deps for
# the C-ext python wheels (dbus-fast, cryptography, pydantic-core).
RUN apt-get update && apt-get install -y --no-install-recommends \
      systemd systemd-sysv dbus dbus-user-session \
      python3 python3-dev python3-pip python3-venv python3-systemd \
      build-essential pkg-config libdbus-1-dev libssl-dev libseccomp-dev libseccomp2 \
      nftables iproute2 iptables cgroup-tools \
      git curl ca-certificates tini tzdata \
    && apt-get clean && rm -rf /var/lib/apt/lists/* \
    # systemd-in-container hygiene: drop units that hang or are pointless headless
    && rm -f /lib/systemd/system/systemd-firstboot.service \
             /lib/systemd/system/getty.target \
             /lib/systemd/system/multi-user.target.wants/systemd-update-utmp* 2>/dev/null || true \
    && systemctl set-default multi-user.target

# Install uv (uvx runner for MCP) — standalone binary, no apt package on noble.
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh \
    && /usr/local/bin/uv --version

# ── Python: hermes-agent (Nous engine, NOT on PyPI) FIRST, then the wheel ─────
# hermes-agent is a Requires-Dist of the wheel but lives only on GitHub; install
# it from the pinned commit tarball so the wheel's dep resolves as satisfied.
ARG HERMES_AGENT_COMMIT=475ecea3d75784d2c1d98279d63ae4e5fba5d497
RUN python3 -m pip install --no-cache-dir \
      "https://github.com/NousResearch/hermes-agent/archive/${HERMES_AGENT_COMMIT}.tar.gz"

# Build the hermes-runtime wheel INSIDE the container (python 3.12), so the build is
# SELF-CONTAINED — the host's python is never used (an old macOS system python 3.9/pip
# can't mis-name it as UNKNOWN-0.0.0). Then install --no-deps + ALL real deps EXPLICITLY
# (core + the browser/shell/tui/mcp extras). No extras-syntax, one package per need.
# APP_CACHEBUST: pass a unique value (build.sh sends $(date +%s)) to force the wheel
# (COPY src) AND everything after — including the ops/ launcher COPY — to rebuild.
# Without this, podman has served STALE `COPY src` / `COPY ops` layers even when the
# content changed, baking old backend code / launcher into a "fresh" image.
ARG APP_CACHEBUST=0
RUN echo "app-cachebust ${APP_CACHEBUST}" > /tmp/.app_cachebust
COPY pyproject.toml README.md /tmp/whlbuild/
COPY src /tmp/whlbuild/src
RUN cd /tmp/whlbuild && python3 -m pip wheel . --no-deps -w /tmp/whl \
    && python3 -m pip install --no-cache-dir --no-deps /tmp/whl/hermes_runtime-*.whl \
    && python3 -m pip install --no-cache-dir \
      aiohttp composio==0.13.1 dbus-fast rfc3161ng structlog tenacity \
      cryptography playwright pytesseract selectolax \
      mcp fastapi 'uvicorn[standard]' python-multipart PyJWT websockets httpx croniter \
      rich textual \
      fastembed \
    # pydantic LAST word (determinism; matches the OS build's pin order)
    && python3 -m pip install --no-cache-dir 'pydantic==2.10.6' 'pydantic-core==2.27.2' \
    && rm -rf /tmp/whlbuild /tmp/whl

# ── React SPA (frontend/) — build INSIDE the container ──────────────────────
# Layer-cache strategy (mirrors the Python wheel-build pattern above):
#   1. Copy only package manifests → npm ci (heavy layer, rarely invalidated).
#   2. Copy the rest of frontend/ → vite build (fast layer, invalidated on src changes).
# Output is placed at /opt/lumen-webapp — the path shell-server reads via the
# LUMEN_REACT_DIST env default (src/hermes/shell_server/main.py: _react_dist).
COPY frontend/package.json frontend/package-lock.json /tmp/frontbuild/
RUN cd /tmp/frontbuild && npm ci --ignore-scripts

# FE_CACHEBUST: pass --build-arg FE_CACHEBUST=<unique> to force a clean rebuild of the
# vite layer (the COPY-frontend layer can stale-cache across iterative rebuilds).
ARG FE_CACHEBUST=0
RUN echo "fe-cachebust ${FE_CACHEBUST}" > /tmp/.fe_cachebust
COPY frontend/ /tmp/frontbuild/
RUN cd /tmp/frontbuild && rm -rf dist && npm run build \
    && rm -rf /opt/lumen-webapp && mkdir -p /opt/lumen-webapp \
    && cp -r dist/. /opt/lumen-webapp/ \
    && rm -rf /tmp/frontbuild

# Browser automation = the npm stack (agent-browser + @playwright/mcp), EXACTLY as
# the OS image runs it. The wheel's python playwright-extra/stagehand-py are not on
# PyPI — the real browser path is node (node 20 ships in the Playwright base). Point
# both at the base's bundled Chromium and symlink it to the unit-expected path
# (Ubuntu apt chromium is a snap stub that won't run in a container).
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
ARG PLAYWRIGHT_MCP_VERSION=0.0.29
RUN npm install -g --ignore-scripts "@playwright/mcp@${PLAYWRIGHT_MCP_VERSION}" agent-browser \
    && chmod +x /usr/lib/node_modules/agent-browser/bin/agent-browser-* \
    && npx --yes playwright install chromium \
    && CHROME="$(find /ms-playwright -type f -name chrome -path '*chrome-linux*' | head -1)" \
    && [ -n "$CHROME" ] && ln -sf "$CHROME" /usr/bin/chromium-browser \
    && echo "chromium -> $CHROME"

# Builder-stage import smoke — fail the BUILD (not runtime) on a missing dep.
RUN python3 -c "import hermes, fastapi, uvicorn, playwright, dbus_fast, composio, mcp, fastembed; \
      import hermes.runtime.__main__, hermes.shell_server.main, hermes.egress_proxy.__main__, \
             hermes.audit_tail_service.__main__, hermes.runtime.semantic_tool_index; \
      from run_agent import AIAgent; from hermes_cli.runtime_provider import resolve_runtime_provider; \
      print('IMPORT SMOKE OK')"

# ── Service accounts — IDENTICAL uids to the OS build ─────────────────────────
# The Playwright base ships a non-root user at UID 1000 (pwuser); remove it so
# hermes-user can take 1000 (the daemon's HERMES_OPERATOR_ID maps to uid 1000).
RUN existing="$(getent passwd 1000 | cut -d: -f1)"; \
      [ -n "$existing" ] && userdel -r "$existing" 2>/dev/null; true
RUN useradd --system --no-create-home --shell /usr/sbin/nologin --uid 880 hermes && \
    useradd --system --no-create-home --shell /usr/sbin/nologin --uid 881 hermes-rc && \
    useradd --system --no-create-home --shell /usr/sbin/nologin --uid 882 hermes-whisper && \
    useradd --system --no-create-home --shell /usr/sbin/nologin --uid 883 hermes-cp && \
    useradd --system --no-create-home --shell /usr/sbin/nologin --uid 885 hermes-egress && \
    useradd --create-home --uid 1000 --groups hermes,systemd-journal hermes-user

# hermes-sandbox (uid 886): the user the AGENT's sandboxed exec runs as — the
# confined terminal (hermes-exec-launcher) and the jailed browse Chromium
# (hermes-browser-launcher). DISTINCT from the daemon's `hermes` so DAC blocks
# the agent from reading/writing the daemon's owner-only files (shell-state.db,
# master.key, …) — including the /proc/<daemon-pid>/fd re-open bypass of
# InaccessiblePaths (red-team HIGH finding 2026-06-19: the agent truncated the
# daemon's DB via a /proc fd). hermes-work is the SHARED group for the agent's
# work areas (workspace, browser-sessions) — members get there WITHOUT joining
# `hermes` (which would expose the daemon's group-readable secrets/config).
RUN groupadd --system hermes-work && \
    useradd --system --no-create-home --shell /usr/sbin/nologin --uid 886 \
            --user-group --groups hermes-work hermes-sandbox && \
    usermod -aG hermes-work hermes && \
    usermod -aG hermes-work hermes-user

# ── /usr/bin service wrappers (units call these → python3 -m <module>) ────────
RUN printf '#!/bin/sh\nexec /usr/bin/python3 -m hermes.runtime.__main__ "$@"\n' \
        > /usr/bin/hermes-runtime && \
    printf '#!/bin/sh\nexec /usr/bin/python3 -m hermes.audit_tail_service "$@"\n' \
        > /usr/bin/hermes-audit-tail && \
    printf '#!/bin/sh\nexec /usr/bin/python3 -m hermes.consent_manager_service "$@"\n' \
        > /usr/bin/hermes-consent-manager && \
    chmod 0755 /usr/bin/hermes-runtime /usr/bin/hermes-audit-tail /usr/bin/hermes-consent-manager && \
    mkdir -p /etc/hermes-consent-manager && touch /etc/hermes-consent-manager/profile-enabled

# ── ops config, VERBATIM (Fedora-agnostic) ───────────────────────────────────
COPY ops/agents-os-edition/systemd/        /usr/lib/systemd/system/
COPY ops/agents-os-edition/systemd-user/   /usr/lib/systemd/user/
COPY ops/agents-os-edition/tmpfiles/       /usr/lib/tmpfiles.d/
COPY ops/agents-os-edition/dbus/org.hermes.Runtime1.conf /usr/share/dbus-1/system.d/
COPY ops/agents-os-edition/netns/          /etc/nftables/hermes/
COPY ops/agents-os-edition/modules-load.d/ /etc/modules-load.d/
COPY ops/agents-os-edition/seed/mcp-servers.json /usr/share/hermes/seed/
# Namespace-pivot seccomp data for the browser-jail shim. The shim reads this exact
# path; when absent it soft-degrades (no per-process CLONE_NEWUSER backstop). Baking
# it makes the in-unit defense-in-depth real instead of relying solely on the outer
# container seccomp profile.
COPY ops/agents-os-edition/seccomp/chromium-browser.json /usr/share/hermes/seccomp/chromium-browser.json

# ── Egress blocklist (hagezi "light" — bundled at build time) ─────────────────
# Proxy reads /usr/share/hermes/egress-blocklist.txt at boot and applies it as an
# immutable system-level blocklist in OPEN_LOGGED (ALLOW) mode. The file is plain
# text, one domain per line, comments with '#'. Fail-soft: curl or download failure
# leaves an empty file — the proxy starts, log shows 0 blocklist entries.
# TODO: add hermes-egress-blocklist-refresh.timer to re-download daily at runtime.
RUN mkdir -p /usr/share/hermes && \
    ( curl -LsSf --max-time 60 \
        "https://raw.githubusercontent.com/hagezi/dns-blocklists/main/domains/light.txt" \
        -o /usr/share/hermes/egress-blocklist.txt \
      && wc -l /usr/share/hermes/egress-blocklist.txt \
      && echo "INFO: hagezi light blocklist bundled" ) \
    || ( echo "WARN: blocklist download failed — using empty list (fail-soft)" \
         && touch /usr/share/hermes/egress-blocklist.txt )
# scripts → /usr/libexec/hermes + /usr/bin (the launchers + jail + landlock assert)
COPY ops/agents-os-edition/scripts/hermes-mcp-launcher    /usr/libexec/hermes/hermes-mcp-launcher
COPY ops/agents-os-edition/scripts/hermes-browser-launcher /usr/libexec/hermes/hermes-browser-launcher
COPY ops/agents-os-edition/scripts/hermes-exec-launcher   /usr/libexec/hermes/hermes-exec-launcher
COPY ops/agents-os-edition/scripts/hermes-browser-jail    /usr/libexec/hermes/browser-jail
COPY ops/agents-os-edition/scripts/hermes-clipboard-server /usr/libexec/hermes/hermes-clipboard-server
COPY ops/agents-os-edition/scripts/hermes-landlock-assert /usr/bin/hermes-landlock-assert
# container-specific drop-ins (override ONLY the OS-coupling: bind host)
COPY ops/container/dropins/ /usr/lib/systemd/system/
RUN chmod 0755 /usr/libexec/hermes/* /usr/bin/hermes-landlock-assert && \
    chown root:root /usr/libexec/hermes/*

# ── OpenShell confinement substrate (the cage shield) — P2 ────────────────────
# The agent's "terminal" routes through OpenShell ExecSandbox (uid 999, landlock
# FS jail, all egress via the L7 proxy) when OpenShell is provisioned. We bake the
# CLI + its libz3 runtime dep + an OPT-IN env drop-in: the deploy writes
# /var/lib/hermes/openshell/openshell.env (HERMES_OPENSHELL_SANDBOX=<sandbox>) once
# the gateway + per-agent sandbox exist; absent → the terminal uses the
# exec-launcher cage. Both paths are fail-closed (never in-daemon).
COPY ops/agent-cage/bin/openshell        /usr/libexec/hermes/openshell
COPY ops/agent-cage/bin/libz3.so.4       /usr/lib/hermes/openshell/libz3.so.4
COPY ops/agent-cage/systemd/hermes-runtime.service.d/openshell.conf \
     /usr/lib/systemd/system/hermes-runtime.service.d/openshell.conf
RUN chmod 0755 /usr/libexec/hermes/openshell && \
    chown root:root /usr/libexec/hermes/openshell /usr/lib/hermes/openshell/libz3.so.4

# socat: the browser-jail CDP relay (daemon ⇄ jailed Chromium) needs it. Without it
# the daemon can't reach the browser's CDP port. (Late layer = cheap rebuild.)
# x11vnc: the jailed browser runs HEADFUL on an Xvfb display (industry-standard
# Kasm/neko live-view — sharp + fluid, unlike the CDP screencast). x11vnc streams
# that real display; the shell-server proxies it to the web UI. (Xvfb ships with
# the Playwright base image.)
# xclip: the clipboard bridge (hermes-clipboard-server) uses it as a PROPER X selection
# owner — it answers the TARGETS request Chromium sends before pasting (which x11vnc's own
# owner does not → paste hangs) and serves UTF8_STRING, so accents/€/emoji/CJK paste right.
RUN apt-get update && apt-get install -y --no-install-recommends socat x11vnc xclip \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Trivy CVE scanner (Security Center CVE slot probes /usr/bin/trivy exactly).
# Strategy:
#   1. Detect arch (uname -m) and resolve to trivy's release naming (x86_64→Linux-64bit,
#      aarch64→Linux-ARM64).  The install.sh helper does the same but by shelling out;
#      doing it explicitly avoids "uname not found" edge cases in restricted build envs.
#   2. Download the pinned release tarball directly from GitHub releases (no
#      install.sh curl-pipe risk; checksum not verified here — keep it simple and
#      best-effort consistent with the existing posture).
#   3. Verify the binary runs (`trivy --version`).
#   4. Log the engine selection AT BUILD TIME so `docker build` output shows which
#      path the image uses.  The daemon also logs at boot via _scan_service_lazy().
# INVARIANT: this entire block is best-effort (`|| echo WARN`).  A failed trivy
# install must never break the image bake — the Security Center's heuristic fallback
# (HeuristicFallbackScanner) is the correct degraded path and is already tested.
ARG TRIVY_VERSION=v0.71.2
# CACHE DIR FUERA DEL VOLUMEN: run-lumen.sh monta `-v lumen-data:/var/lib/hermes`,
# así que una DB horneada bajo /var/lib/hermes/* queda SOMBREADA por el volumen en
# runtime → trivy no la encuentra → degrada a [] = teatro (este era el bug). En
# /var/lib/trivy (fuera del volumen) la DB horneada SOBREVIVE al arranque. El daemon
# (ProtectSystem=strict) la lee porque la unit añade /var/lib/trivy a ReadWritePaths
# y Environment=TRIVY_CACHE_DIR=/var/lib/trivy; el runtime usa --skip-db-update.
ENV TRIVY_CACHE_DIR=/var/lib/trivy
RUN ARCH="$(uname -m)"; \
    case "$ARCH" in \
      x86_64)   TRIVY_ARCH="Linux-64bit"  ;; \
      aarch64)  TRIVY_ARCH="Linux-ARM64"  ;; \
      armv7l)   TRIVY_ARCH="Linux-ARM"    ;; \
      *)        echo "WARN: trivy — unknown arch $ARCH, skipping install"; exit 0 ;; \
    esac; \
    TRIVY_VER="${TRIVY_VERSION#v}"; \
    TRIVY_URL="https://github.com/aquasecurity/trivy/releases/download/${TRIVY_VERSION}/trivy_${TRIVY_VER}_${TRIVY_ARCH}.tar.gz"; \
    echo "▸ trivy install: arch=${TRIVY_ARCH} ver=${TRIVY_VER}"; \
    ( curl -LsSf "$TRIVY_URL" -o /tmp/trivy.tgz \
      && tar -xzf /tmp/trivy.tgz -C /usr/bin trivy \
      && chmod 0755 /usr/bin/trivy \
      && rm -f /tmp/trivy.tgz \
      && /usr/bin/trivy --version \
      && echo "INFO: trivy installed — Security Center will use engine=trivy" ) \
    || echo "WARN: trivy install failed — Security Center will use engine=heuristic (honest fallback)"
# Pre-warm the trivy vuln DB so `trivy fs` works OFFLINE under the cage (runtime
# egress is denied). Without a baked DB trivy would fetch at scan time, fail, and
# the cve slot would be unanalyzable. TRIVY_CACHE_DIR set above (ENV) so all trivy
# invocations use the same baked path at build and runtime.
#
# FAIL-THE-BUILD when the binary is present but the DB prewarm fails (security-review
# 2026-06-26): engine selection picks trivy on a usable DB, so an image that shipped
# trivy WITHOUT a DB would mark every install unanalyzable. If trivy installed, the
# DB MUST be present — otherwise abort the bake. If trivy is ABSENT (arch/install
# failed earlier), skip silently — the honest heuristic fallback is the correct path.
#
# OWNER-ONLY perms (security-review 2026-06-26): the DB is owned by hermes:hermes and
# NOT group-writable. The daemon (uid 880, owner) reads the DB and writes trivy's
# working metadata as owner; the sandboxed agent (hermes-sandbox ∈ hermes-work) must
# NOT be able to write/poison the vuln DB. World-read is fine (the DB is public data).
RUN mkdir -p "${TRIVY_CACHE_DIR}"; \
    if [ -x /usr/bin/trivy ]; then \
      TRIVY_CACHE_DIR="${TRIVY_CACHE_DIR}" /usr/bin/trivy image --download-db-only \
        --db-repository ghcr.io/aquasecurity/trivy-db 2>&1 | tail -3; \
      if [ ! -f "${TRIVY_CACHE_DIR}/db/trivy.db" ]; then \
        echo "FATAL: trivy present but DB prewarm failed — refusing to ship trivy-without-DB"; \
        exit 1; \
      fi; \
      echo "INFO: trivy DB pre-warmed at ${TRIVY_CACHE_DIR}"; \
    else \
      echo "INFO: trivy absent — skipping DB prewarm (Security Center uses heuristic)"; \
    fi; \
    chown -R hermes:hermes "${TRIVY_CACHE_DIR}"; \
    chmod -R u=rwX,go=rX "${TRIVY_CACHE_DIR}"

# ── Semantic tool-retrieval model (fastembed, ONNX, CPU) — baked OFFLINE ───────
# Intent-based tool retrieval (runtime/semantic_tool_index.py) embeds each connected-
# integration tool and ranks them by the turn's intent, so a weak model sees a handful
# of RELEVANT tools instead of hundreds (gmail alone is ~63). The multilingual MiniLM
# ONNX model is baked to /var/lib/fastembed — OUTSIDE the runtime volume, the SAME
# rationale as the trivy DB above: a model under /var/lib/hermes/* would be SHADOWED by
# an existing volume on upgrade → runtime re-download → offline installs break. The
# hermes-runtime unit sets HERMES_TOOL_EMBED_CACHE=/var/lib/fastembed and adds the path
# to ReadWritePaths. Owner hermes:hermes (the daemon may write HF lock files on load);
# world-read (the model is public data); the sandboxed agent has no path to it.
# FAIL-THE-BUILD if the bake fails so a shipped image always has a working index — the
# in-code fallback (retrieval disabled → full tool set kept) is a degraded runtime
# safety net, not a licence to ship an image without the model. Single RUN so the
# download + chown share one layer (no ~220MB metadata-copy duplication).
RUN mkdir -p /var/lib/fastembed \
    && python3 -c "from fastembed import TextEmbedding; \
m = TextEmbedding(model_name='sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2', cache_dir='/var/lib/fastembed'); \
v = list(m.embed(['warmup'])); \
assert v and len(v[0]) == 384, 'unexpected embed dim'; \
print('INFO: fastembed model baked (dim=%d) at /var/lib/fastembed' % len(v[0]))" \
    && chown -R hermes:hermes /var/lib/fastembed \
    && chmod -R u=rwX,go=rX /var/lib/fastembed

# Hardening (V): strip ALL SUID-root bits. The cage uses systemd capabilities
# (NET_ADMIN/SYS_ADMIN on the root units), NOT SUID — so su/mount/passwd/chfn/
# gpasswd/newgrp SUID are pure privesc surface for a compromised non-root agent.
# Chromium runs --no-sandbox so its SUID helper is unused. Remove the surface.
RUN find / -xdev -perm -4000 -type f -exec chmod u-s {} + 2>/dev/null; \
    find / -xdev -perm -2000 -type f -exec chmod g-s {} + 2>/dev/null; \
    echo "SUID/SGID restantes:"; find / -xdev -perm -4000 -o -perm -2000 2>/dev/null | head || true

# ── writable dirs + ownership (tmpfiles re-asserts at boot too) ───────────────
RUN mkdir -p /var/lib/hermes /opt/hermes /run/hermes && \
    chown -R hermes:hermes /var/lib/hermes /opt/hermes /run/hermes
# Shared work areas: group hermes-work + setgid (2770) so the agent's sandboxed
# exec (User=hermes-sandbox) and the daemon/compositor (group hermes-work) both
# read+write them, while the daemon's secrets stay owner-only / group `hermes`.
# tmpfiles re-asserts these at every boot (authoritative); this is the bake-time
# baseline.
RUN mkdir -p /var/lib/hermes/workspace /var/lib/hermes/browser-sessions && \
    chgrp hermes-work /var/lib/hermes/workspace /var/lib/hermes/browser-sessions && \
    chmod 2770 /var/lib/hermes/workspace /var/lib/hermes/browser-sessions

# ── Pre-warm the curated MCP cache (sellable clean image: "download → works") ──
# The MCP runtime spawns OFFLINE (launcher injects npx --prefer-offline) from
# /var/lib/hermes/npm-cache (hermes-mcp-launcher.service Environment). A FRESH install
# has an empty cache, so the SEEDED npx MCPs (ruflo) fail at boot with
# "Connection closed" (the cage denies npm at runtime — C1 PASS-3). Warm the cache at
# BUILD with the EXACT specs the seed runs (ops/.../seed/mcp-servers.json) so the full
# dep tree is cached. /var/lib/hermes is volume-copied-up into the customer's fresh
# volume on first boot → the seeded MCPs connect OFFLINE, out of the box, no grant.
ENV npm_config_cache=/var/lib/hermes/npm-cache
ENV UV_CACHE_DIR=/var/lib/hermes/uv-cache
ENV XDG_CACHE_HOME=/var/lib/hermes/xdg-cache
# Warm BOTH runner caches with the EXACT seed specs (ops/.../seed/mcp-servers.json) so the
# curated MCPs connect OFFLINE on a fresh boot (the cage denies npm/uv at runtime). npx →
# npm-cache (@pinkpixel/mcpollinations: imagen/audio sin clave); uvx → UV_CACHE_DIR (Excel /
# Word / PowerPoint, locales sin clave). /var/lib/hermes is volume-copied-up on first boot.
RUN mkdir -p /var/lib/hermes/npm-cache /var/lib/hermes/uv-cache /var/lib/hermes/xdg-cache \
      /var/lib/hermes/mcp-home && \
    for spec in "excel-mcp-server stdio" \
                "--from office-word-mcp-server word_mcp_server" \
                "--from office-powerpoint-mcp-server ppt_mcp_server"; do \
      echo "▸ warming uvx $spec" ; \
      HOME=/var/lib/hermes/mcp-home timeout 240 uvx $spec </dev/null >/dev/null 2>&1 || true ; \
    done ; \
    chown -R hermes:hermes-work /var/lib/hermes/npm-cache /var/lib/hermes/uv-cache \
      /var/lib/hermes/xdg-cache /var/lib/hermes/mcp-home && \
    chmod -R g+rwX /var/lib/hermes/npm-cache /var/lib/hermes/uv-cache \
      /var/lib/hermes/xdg-cache /var/lib/hermes/mcp-home

# ── enable the same service set the terminal variant runs ────────────────────
# The individual enables populate hermes-workspace.target.wants/ (each service's
# [Install] is WantedBy=hermes-workspace.target). Enabling the TARGET itself
# (WantedBy=multi-user.target) is what actually ACTIVATES it at boot → which pulls
# the launchers (browser/exec/mcp). Without the target enabled, only the services
# that hermes-runtime Wants= directly (netns, egress-proxy) come up, and the
# launchers stay inactive → their control sockets never appear.
RUN systemctl enable \
      hermes-keygen.service hermes-runtime.service hermes-shell-server.service \
      hermes-mcp-launcher.service hermes-egress-proxy.service \
      hermes-browser-netns.service hermes-browser-launcher.service \
      hermes-exec-launcher.service \
      hermes-audit-tail.service \
      hermes-workspace.target 2>&1 | tail -3 || true

# ── Edition marker + EE service gate ─────────────────────────────────────────
# Write the build-time edition to a file so the runtime can report it without
# querying the association store.  shell-server reads /usr/share/hermes/edition
# at startup and exposes it on /api/v1/profile.
# The ARG is re-declared after the FROM so it is in scope for this RUN layer.
ARG LUMEN_EDITION=community
RUN mkdir -p /usr/share/hermes && echo "${LUMEN_EDITION}" > /usr/share/hermes/edition
# Bake the build provenance (git SHA) so anyone can confirm EXACTLY which commit an
# image was built from — `podman run --rm <img> cat /usr/share/hermes/build` (or the
# OCI label org.opencontainers.image.revision). CI passes GIT_SHA=${{ github.sha }};
# local builds default to "dev". This ends the "which version am I running?" guesswork.
ARG GIT_SHA=dev
RUN echo "${GIT_SHA}" > /usr/share/hermes/build
LABEL org.opencontainers.image.revision="${GIT_SHA}"
# Cloud config-sync: enable it UNCONDITIONALLY (both editions). The unit's
# ConditionPathExists=/var/lib/hermes/instance/.enterprise keeps it inert in
# community edition (no pairing marker) and auto-starts it the moment an instance
# is paired — the CE image runs in associate mode, so gating on build-time
# LUMEN_EDITION would (and did) leave paired CE instances without policy sync.
RUN systemctl enable hermes-config-sync.service 2>&1 | tail -3 || true

# podman-machine (macOS) compat: systemd's per-unit MemoryPressureWatch tries to bind the
# unit's cgroup memory.pressure into its namespace; in the Mac podman VM's cgroup view this
# fails "Permission denied" → 226/NAMESPACE → every hardened unit (hermes-runtime, the
# netns, …) crash-loops, even rootful. It is a minor memory-pressure NOTIFICATION feature,
# NOT part of the cage (netns/nftables/Landlock/seccomp/uid-split are independent). Disable
# it globally so the units' mount-namespace setup succeeds. Linux deploys are unaffected.
COPY ops/container/system.conf.d/10-no-mempressure.conf /etc/systemd/system.conf.d/

EXPOSE 7517
STOPSIGNAL SIGRTMIN+3
HEALTHCHECK --interval=30s --timeout=5s --start-period=120s --retries=3 \
  CMD curl -fsS http://127.0.0.1:7517/ >/dev/null || exit 1
ENTRYPOINT ["/usr/lib/systemd/systemd"]
