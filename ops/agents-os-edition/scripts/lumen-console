#!/bin/bash
# lumen-console — what the VM console (tty1) shows. The face of Lumen is the WEB
# UI (served by hermes-shell-server); this screen just points the operator to it
# and shows live service status. It loops forever (kiosk) so the console never
# drops to a shell.
set +e
PORT="${HERMES_SHELL_BIND_PORT:-7517}"
while true; do
  clear 2>/dev/null || true
  IP=$(ip -4 -o addr show scope global 2>/dev/null | awk '{print $4}' | cut -d/ -f1 | head -1)
  printf '\n\n'
  printf '      \033[1;38;5;39m◆  Lumen\033[0m\n\n'
  printf '      Tu agente de trabajo personal está en marcha.\n\n'
  printf '      Abre Lumen en tu navegador:\n\n'
  printf '          \033[1;38;5;39mhttp://%s:%s\033[0m\n\n' "${IP:-<ip-de-esta-VM>}" "$PORT"
  printf '      (desde tu equipo / tu Mac)\n\n\n'
  rt=$(systemctl is-active hermes-runtime 2>/dev/null)
  ss=$(systemctl is-active hermes-shell-server 2>/dev/null)
  printf '      estado:  cerebro=%s · interfaz=%s\n' "$rt" "$ss"
  printf '\n      (Ctrl+Alt+F2 para una consola de sistema)\n'
  sleep 20
done
