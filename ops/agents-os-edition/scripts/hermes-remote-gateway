#!/usr/bin/env python3
"""hermes-remote-gateway — reverse proxy de UN SOLO ORIGEN para el acceso remoto.

Un ÚNICO quicktunnel de cloudflared apunta aquí (127.0.0.1:6088). Enrutamos por path:

    /files/<relpath>  → descarga de entregables de /var/lib/hermes/workspace/
    /clipboard*       → servidor QClipboard del compositor (127.0.0.1:7519)
    WebSocket         → websockify/noVNC (127.0.0.1:6080)   [stream RFB]
    resto             → websockify/noVNC (127.0.0.1:6080)   [estáticos vnc.html, app/*, core/*]

POR QUÉ UN SOLO ORIGEN (fix 2026-06-11):
  El diseño anterior abría DOS quicktunnels (noVNC + clipboard) y un watchdog que,
  al reintentar cada ~20 s, disparaba el rate-limit de trycloudflare
  (HTTP 429 / error 1015 "Too Many Requests") → el 2º túnel moría al instante y el
  clipboard remoto nunca se exponía. Con un solo túnel:
    · cero 2ª URL efímera (el overlay usa MISMO ORIGEN → /clipboard),
    · sin CORS, sin watchdog,
    · la mitad de exposición al rate-limit (un cliente cloudflared, no dos).

El compositor sirve su framebuffer por VNC loopback (:5900), websockify lo expone en
:6080, y el clipboard QClipboard del compositor en :7519. Este gateway los unifica
bajo el único túnel para que el usuario real copie/pegue con Cmd/Ctrl+V sin carpintería.

/files/<relpath>: sirve SOLO ficheros de /var/lib/hermes/workspace/. El gateway corre
como User=hermes (grupo hermes) con acceso de lectura al workspace (0770 hermes:hermes).
Seguridad path-traversal: realpath + prefijo. Nunca lista directorios; solo GET.

Requiere aiohttp (presente en el site-packages del SO). Sin estado, sin escritura a disco.
"""
from __future__ import annotations

import asyncio
import logging
import mimetypes
import os
import sys
from pathlib import Path

from aiohttp import ClientSession, ClientTimeout, WSMsgType, web

NOVNC = "http://127.0.0.1:6080"
CLIP = "http://127.0.0.1:7519"
HOST = "127.0.0.1"
PORT = 6088

# Directorio raíz de entregables del Cerebro.
# 0770 hermes:hermes — el gateway corre como hermes (o grupo hermes) → acceso de lectura.
_WORKSPACE = Path("/var/lib/hermes/workspace")

# Cabeceras hop-by-hop que NO se reenvían (las gestiona cada salto).
_HOP = {
    "connection", "keep-alive", "proxy-authenticate", "proxy-authorization",
    "te", "trailers", "transfer-encoding", "upgrade", "content-length",
    "content-encoding", "host",
}

logging.basicConfig(
    level=logging.INFO,
    format="%(levelname)s hermes-remote-gateway: %(message)s",
    stream=sys.stderr,
)
log = logging.getLogger("hermes-remote-gateway")


def _resolve_workspace_file(relpath: str) -> Path | None:
    """Resuelve y valida un relpath contra _WORKSPACE.

    Devuelve el Path absoluto canonicalizado si es seguro, None si escapa
    del workspace (path traversal, symlink fuera del árbol, etc.).

    Seguridad:
      - os.path.realpath() resuelve todos los symlinks antes de comparar.
      - startswith() contra la raíz real del workspace (también canonicalizada).
      - Rechaza '..' y '/' en el relpath ANTES de construir la ruta (fail-early).
    """
    # Rechazar relpaths que intentan salir del workspace con '..' o raíz absoluta.
    if relpath.startswith("/") or ".." in relpath.split("/"):
        return None

    candidate = _WORKSPACE / relpath
    # Canonicaliza: sigue symlinks y limpia '..' que pudieran quedar.
    real_candidate = Path(os.path.realpath(candidate))
    real_workspace = Path(os.path.realpath(_WORKSPACE))

    # El fichero resuelto debe estar DENTRO del workspace (prefijo estricto).
    try:
        real_candidate.relative_to(real_workspace)
    except ValueError:
        return None

    if not real_candidate.is_file():
        return None

    return real_candidate


async def _serve_workspace_file(request: web.Request) -> web.Response:
    """GET /files/<relpath> — descarga de entregables del Cerebro.

    Content-Disposition: attachment fuerza la descarga en el navegador.
    Solo GET; solo ficheros (no directorios); path-traversal seguro.
    """
    relpath: str = request.match_info.get("relpath", "")
    if not relpath:
        return web.Response(status=400, text="relpath requerido")

    resolved = _resolve_workspace_file(relpath)
    if resolved is None:
        log.warning("workspace file rejected path=%r (traversal o no existe)", relpath)
        return web.Response(status=403, text="acceso denegado")

    filename = resolved.name
    mime_type, _ = mimetypes.guess_type(str(resolved))
    if mime_type is None:
        mime_type = "application/octet-stream"

    log.info("workspace file serve path=%s mime=%s", resolved, mime_type)
    try:
        return web.FileResponse(
            path=resolved,
            headers={
                "Content-Disposition": f'attachment; filename="{filename}"',
                "Content-Type": mime_type,
            },
        )
    except PermissionError:
        log.error("workspace file permission denied path=%s", resolved)
        return web.Response(status=403, text="acceso denegado")


def _clean_headers(headers) -> dict:
    return {k: v for k, v in headers.items() if k.lower() not in _HOP}


async def _proxy_http(request: web.Request, base: str, session: ClientSession) -> web.Response:
    target = base + request.rel_url.raw_path_qs
    body = await request.read()
    try:
        async with session.request(
            request.method,
            target,
            headers=_clean_headers(request.headers),
            data=body if body else None,
            allow_redirects=False,
        ) as r:
            data = await r.read()
            resp = web.Response(status=r.status, body=data)
            for k, v in r.headers.items():
                if k.lower() not in _HOP:
                    resp.headers[k] = v
            return resp
    except Exception as exc:  # noqa: BLE001 — un proxy SIEMPRE responde
        log.warning("http proxy error path=%s: %s", request.path, exc)
        return web.Response(status=502, text="gateway error")


async def _proxy_ws(request: web.Request, base: str) -> web.WebSocketResponse:
    requested = request.headers.get("Sec-WebSocket-Protocol", "")
    protocols = [p.strip() for p in requested.split(",") if p.strip()]
    # max_msg_size=0 → sin límite: los framebuffer updates de VNC pueden ser grandes.
    ws_server = web.WebSocketResponse(protocols=protocols or (), max_msg_size=0)
    await ws_server.prepare(request)
    url = base.replace("http", "ws", 1) + request.rel_url.raw_path_qs
    try:
        async with ClientSession() as cs:
            async with cs.ws_connect(
                url, protocols=protocols or (), max_msg_size=0
            ) as ws_client:

                async def server_to_client() -> None:
                    async for msg in ws_client:
                        if msg.type == WSMsgType.BINARY:
                            await ws_server.send_bytes(msg.data)
                        elif msg.type == WSMsgType.TEXT:
                            await ws_server.send_str(msg.data)
                        elif msg.type in (
                            WSMsgType.CLOSE, WSMsgType.CLOSING, WSMsgType.CLOSED, WSMsgType.ERROR,
                        ):
                            break

                async def client_to_server() -> None:
                    async for msg in ws_server:
                        if msg.type == WSMsgType.BINARY:
                            await ws_client.send_bytes(msg.data)
                        elif msg.type == WSMsgType.TEXT:
                            await ws_client.send_str(msg.data)
                        elif msg.type in (
                            WSMsgType.CLOSE, WSMsgType.CLOSING, WSMsgType.CLOSED, WSMsgType.ERROR,
                        ):
                            break

                await asyncio.gather(
                    server_to_client(), client_to_server(), return_exceptions=True
                )
    except Exception as exc:  # noqa: BLE001
        log.warning("ws proxy error: %s", exc)
    finally:
        if not ws_server.closed:
            await ws_server.close()
    return ws_server


async def _handler(request: web.Request):
    # Match EXACTO de /clipboard (no startswith): si no, /clipboard-overlay.js —el
    # propio script del overlay— se enrutaría al server :7519 (que solo sirve
    # /clipboard) → 404 → el overlay no cargaría. El endpoint del clipboard es solo
    # /clipboard (con o sin barra final).
    if request.path.rstrip("/") == "/clipboard":
        return await _proxy_http(request, CLIP, request.app["clip"])
    if request.headers.get("Upgrade", "").lower() == "websocket":
        return await _proxy_ws(request, NOVNC)
    return await _proxy_http(request, NOVNC, request.app["novnc"])


async def _make_app() -> web.Application:
    app = web.Application()
    app["clip"] = ClientSession(timeout=ClientTimeout(total=15))
    app["novnc"] = ClientSession(timeout=ClientTimeout(total=60))

    async def _close(app_: web.Application) -> None:
        await app_["clip"].close()
        await app_["novnc"].close()

    app.on_cleanup.append(_close)
    # /files/<relpath> ANTES del catch-all: la ruta con nombre explícito tiene
    # prioridad sobre /{tail:.*}. Solo GET (no POST/PUT/DELETE).
    app.router.add_get("/files/{relpath:.*}", _serve_workspace_file)
    app.router.add_route("*", "/{tail:.*}", _handler)
    return app


def main() -> None:
    log.info(
        "hermes-remote-gateway escuchando en %s:%d "
        "(noVNC=%s clipboard=%s workspace=%s)",
        HOST, PORT, NOVNC, CLIP, _WORKSPACE,
    )
    web.run_app(_make_app(), host=HOST, port=PORT, print=None, access_log=None)


if __name__ == "__main__":
    main()
