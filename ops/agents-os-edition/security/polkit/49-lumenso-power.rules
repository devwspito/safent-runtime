// LumenSO — el dueño de la sesión (hermes-user) gobierna SU máquina.
//
// El SO es de usuario único: hermes-user ES el operador. Debe poder apagar,
// reiniciar la máquina y reiniciar el daemon Hermes desde la UI sin que polkit
// pida contraseña (no hay un segundo usuario admin a quien escalar).
//
// Least-privilege: solo se conceden las acciones de energía de logind y la
// gestión de UNA unidad concreta (hermes-runtime.service). No se toca el resto
// de polkit ni se da gestión libre de unidades.
//
// Requiere sesión local activa (subject.local && subject.active) — un acceso
// remoto noVNC entra como esa misma sesión local del seat, así que aplica.

polkit.addRule(function(action, subject) {
    if (subject.user !== "hermes-user") return polkit.Result.NOT_HANDLED;
    if (!subject.local || !subject.active) return polkit.Result.NOT_HANDLED;

    // Apagar / reiniciar la máquina (logind).
    if (action.id === "org.freedesktop.login1.power-off" ||
        action.id === "org.freedesktop.login1.power-off-multiple-sessions" ||
        action.id === "org.freedesktop.login1.reboot" ||
        action.id === "org.freedesktop.login1.reboot-multiple-sessions") {
        return polkit.Result.YES;
    }

    // Reiniciar SOLO el daemon Hermes (gestión de esa unidad).
    if (action.id === "org.freedesktop.systemd1.manage-units") {
        var unit = action.lookup("unit");
        if (unit === "hermes-runtime.service") return polkit.Result.YES;
    }

    return polkit.Result.NOT_HANDLED;
});
