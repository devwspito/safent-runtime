# hermes-control-plane.service — solo perfil server (y workspace-only opcional).

[Unit]
Description=Hermes Control Plane (FastAPI multi-tenant)
After=postgresql.service network-online.target
Requires=postgresql.service
ConditionPathExists=/etc/hermes-control-plane/profile-enabled
StartLimitBurst=10
StartLimitIntervalSec=60

[Service]
Type=notify
User=hermes-cp
Group=hermes-cp
ExecStart=/opt/hermes-control-plane/bin/hermes-control-plane --systemd-notify
WatchdogSec=30
Restart=always
RestartSec=2

Slice=agents-os.slice
MemoryMin=512M
MemoryMax=4G
OOMScoreAdjust=-500

# Hardening.
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=yes
PrivateUsers=yes
ReadWritePaths=/var/lib/hermes /run/hermes-cp
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
