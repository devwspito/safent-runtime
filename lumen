#!/bin/sh
# lumen - control the local Lumen container from your terminal.
#
#   lumen            open Lumen in the browser (starts it if stopped)
#   lumen stop       stop Lumen
#   lumen start      start Lumen without opening the browser
#   lumen restart    restart Lumen
#   lumen update     pull the latest image and recreate (keeps your config)
#   lumen status     is it running? on which port?
#   lumen logs       follow the container journal
#
# ASCII-only + POSIX sh on purpose (portable across macOS bash 3.2 / dash / zsh-as-sh).
# The model, Composio, Brave, agents and skills are all configured IN THE UI.
set -e

# ONE runtime image for both community and associate (paired) operation. The
# image carries no edition-specific code: pairing state (the .enterprise marker +
# is_associated()) is what activates associate behavior at runtime, so the same
# image runs both roles. There is intentionally no separate "enterprise" image.
IMAGE="${LUMEN_IMAGE:-ghcr.io/devwspito/lumen:latest}"
NAME="${LUMEN_NAME:-lumen}"
PORT_PIN="${LUMEN_PORT:-}"
# Enterprise cloud the instance pairs/syncs against. Empty for community edition.
# Forwarded into the container at run (-e) AND to the pair handshake (--cloud) so
# the personalized curl one-liner (LUMEN_CLOUD_ENDPOINT=... lumen pair) reaches
# the tenant's cloud instead of the default https://cloud.lumen.run.
CLOUD_ENDPOINT="${LUMEN_CLOUD_ENDPOINT:-}"
# Named volume that holds the persistent state (config, identity, skills, memory).
# Override LUMEN_DATA_VOLUME to run more than one isolated instance on one host.
DATA_VOLUME="${LUMEN_DATA_VOLUME:-lumen-data}"
SECCOMP_URL="${LUMEN_SECCOMP_URL:-https://raw.githubusercontent.com/devwspito/lumen-runtime/main/ops/container/seccomp/lumen.json}"
SECCOMP_DIR="${HOME:-/tmp}/.lumen"
SECCOMP="$SECCOMP_DIR/lumen-seccomp.json"

RT="$(command -v podman 2>/dev/null || command -v docker 2>/dev/null || true)"
[ -n "$RT" ] || { echo "[x] You need podman or docker.  ->  https://podman.io/get-started"; exit 1; }
RTN="$(basename "$RT")"
OS="$(uname -s 2>/dev/null || echo unknown)"

# ---- helpers ----------------------------------------------------------------

_exists()  { "$RT" inspect "$NAME" >/dev/null 2>&1; }
_running() { [ "$("$RT" inspect -f '{{.State.Running}}' "$NAME" 2>/dev/null || echo false)" = true ]; }

# Pairing marker — written to the persistent volume on pair, removed on unpair.
# Stored inside the volume so it survives container recreates. config-sync's
# systemd ConditionPathExists keys off this marker, so the launcher keeps writing
# it; it no longer selects a different image (there is only one).
_ENTERPRISE_MARKER="/var/lib/hermes/instance/.enterprise"

# Single image for every role. Kept as a function so existing call sites are
# untouched and a future per-instance image override stays a one-line change.
_image() {
  echo "$IMAGE"
}

# macOS: the cage runs inside a podman machine, which MUST be rootful.
_ensure_machine() {
  [ "$RTN" = podman ] && [ "$OS" = Darwin ] || return 0
  name="$(podman machine list -q 2>/dev/null | head -1)"
  if [ -z "$name" ]; then
    echo "[*] No podman machine - creating a rootful one (first time only, takes a bit)..."
    podman machine init --rootful --cpus 4 --memory 8192 --disk-size 60 \
      && podman machine start \
      || { echo "[x] Could not create/start the podman machine."; exit 1; }
    name="$(podman machine list -q 2>/dev/null | head -1)"
  fi
  rootful="$(podman machine inspect "$name" --format '{{.Rootful}}' 2>/dev/null | head -1)"
  if [ "$rootful" != "true" ]; then
    echo "[x] The podman machine '$name' is rootless; the cage needs rootful. Convert it:"
    echo "    podman machine stop '$name' && podman machine set --rootful '$name' && podman machine start '$name'"
    exit 1
  fi
  podman info >/dev/null 2>&1 || podman machine start "$name" >/dev/null 2>&1 || true
}

# seccomp profile under $HOME (on macOS the VM mounts $HOME but NOT /tmp).
_ensure_seccomp() {
  mkdir -p "$SECCOMP_DIR" 2>/dev/null || true
  if ! curl -fsSL "$SECCOMP_URL" -o "$SECCOMP" 2>/dev/null; then
    echo "[x] Could not download the seccomp profile ($SECCOMP_URL)."
    echo "    Export LUMEN_SECCOMP_URL to a reachable URL if the repo is not public."
    exit 1
  fi
}

# Recreate the container with the hardened cage (loopback + min caps + seccomp).
# Uses _image() (single runtime image, paired or not).
_run() {
  _ensure_machine
  _ensure_seccomp
  _active_image="$(_image)"
  "$RT" rm -f "$NAME" >/dev/null 2>&1 || true
  if [ -n "$PORT_PIN" ]; then publish="127.0.0.1:${PORT_PIN}:7517"; else publish="127.0.0.1::7517"; fi
  "$RT" run -d --name "$NAME" --systemd=always \
    -p "$publish" \
    ${CLOUD_ENDPOINT:+-e LUMEN_CLOUD_ENDPOINT=$CLOUD_ENDPOINT} \
    --cap-add NET_ADMIN --cap-add SYS_ADMIN --cap-add AUDIT_READ \
    --security-opt seccomp="$SECCOMP" \
    --security-opt unmask=/sys/kernel/security \
    --security-opt label=disable \
    -v /sys/kernel/security:/sys/kernel/security:ro \
    -v "$DATA_VOLUME":/var/lib/hermes \
    --shm-size=1g \
    "$_active_image" >/dev/null
}

_port() {
  if [ -n "$PORT_PIN" ]; then echo "$PORT_PIN"; return; fi
  p="$("$RT" port "$NAME" 7517 2>/dev/null | head -1 | sed 's/.*:\([0-9][0-9]*\)$/\1/')"
  if [ -n "$p" ]; then echo "$p"; else echo 17517; fi
}

# Wait until the runtime is active and print the URL with the ?k= handshake.
_url() {
  secret=""
  i=0
  while [ "$i" -lt 48 ]; do
    a="$("$RT" exec "$NAME" systemctl is-active hermes-runtime 2>/dev/null || true)"
    if [ "$a" = active ]; then
      secret="$("$RT" exec "$NAME" cat /var/lib/hermes-bootstrap/bootstrap/webui-bootstrap 2>/dev/null | tr -d '\r\n' || true)"
      [ -n "$secret" ] && break
    fi
    [ "$a" = failed ] && break
    sleep 5
    i=$((i + 1))
  done
  [ -n "$secret" ] || { echo ""; return 1; }
  echo "http://localhost:$(_port)/?k=${secret}"
}

_open_browser() {
  if command -v open >/dev/null 2>&1; then open "$1" >/dev/null 2>&1 || true
  elif command -v xdg-open >/dev/null 2>&1; then xdg-open "$1" >/dev/null 2>&1 || true
  fi
}

_open_and_print() {
  echo "[*] Waiting for Lumen..."
  url="$(_url)" || url=""
  if [ -n "$url" ]; then
    echo ""
    echo "  Lumen is ready:"
    echo "     $url"
    echo ""
    _open_browser "$url"
  else
    echo "  [!] Lumen started but I could not get the token. Check:  lumen logs"
    exit 1
  fi
}

# ---- subcommands ------------------------------------------------------------

cmd_open() {
  _ensure_machine
  if _exists; then
    _running || { echo "[*] Starting Lumen..."; "$RT" start "$NAME" >/dev/null 2>&1 || true; }
  else
    echo "[*] First run - downloading and starting Lumen..."
    "$RT" pull "$IMAGE" >/dev/null 2>&1 || true
    _run
  fi
  _open_and_print
}

cmd_start() {
  _ensure_machine
  if _exists; then
    if _running; then echo "[ok] Lumen is already running (run 'lumen' to open it)."; return; fi
    "$RT" start "$NAME" >/dev/null 2>&1 || true
    echo "[ok] Lumen started. Open it with:  lumen"
  else
    "$RT" pull "$IMAGE" >/dev/null 2>&1 || true
    _run
    echo "[ok] Lumen started. Open it with:  lumen"
  fi
}

cmd_stop() {
  if _exists && _running; then
    if "$RT" stop "$NAME" >/dev/null 2>&1; then echo "[ok] Lumen stopped."; else echo "[x] Could not stop it."; fi
  else
    echo "[ok] Lumen was already stopped."
  fi
}

cmd_restart() { cmd_stop; cmd_open; }

cmd_update() {
  echo "[*] Fetching the latest Lumen image..."
  _ensure_machine
  # Reclaim disk BEFORE pulling. Each previous update left the old image DANGLING
  # (its :latest tag moved to the new pull) and each hoards ~7 GB. If we only pruned
  # AFTER the pull (as before), a disk that had already filled up over time made the
  # pull itself fail with "no space left on device" — and the prune never ran, so it
  # stayed stuck. Pruning dangling images + build cache first frees that space so the
  # pull has room. This NEVER touches the lumen-data volume (your keystore/MFA/
  # providers/config) nor the running container's current tagged image.
  echo "[*] Reclaiming space from previous versions (your data is untouched)..."
  "$RT" image prune -f  >/dev/null 2>&1 || true
  "$RT" builder prune -f >/dev/null 2>&1 || true
  # Pull the correct image (enterprise or community) based on the current marker.
  "$RT" pull "$(_image)"
  echo "[*] Recreating the container with the new image..."
  _run   # -v lumen-data keeps your config (keystore, MFA, providers)
  # The image we were running until a second ago is now dangling too (the tag moved
  # to what we just pulled, and the container was recreated) → prune it as well.
  "$RT" image prune -f >/dev/null 2>&1 || true
  _open_and_print
}

# ---- enterprise pairing -----------------------------------------------------
# Pairing turns this SAME image into the cloud-managed associate at runtime — no
# separate image to pull. The handshake writes the association row + the
# .enterprise marker; the marker gates config-sync (ConditionPathExists), which
# then pulls and applies signed cloud policy.

cmd_pair() {
  _code="$1"
  if [ -z "$_code" ]; then
    echo "[x] Usage: lumen pair <code>"; exit 1
  fi
  _ensure_machine
  # Ensure the container is running before we exec into it.
  if ! _running; then
    echo "[*] Starting Lumen to complete pairing..."
    cmd_start
  fi
  # Run the pairing handshake inside the container.
  # Code is passed via stdin (not argv) to avoid exposure in process listings.
  echo "[*] Running pairing handshake..."
  printf '%s' "$_code" | "$RT" exec -i "$NAME" python3 -m hermes.instance pair --stdin ${CLOUD_ENDPOINT:+--cloud "$CLOUD_ENDPOINT"} || { echo "[x] Pairing failed."; exit 1; }
  # Write the pairing marker so config-sync's ConditionPathExists gate opens.
  "$RT" exec "$NAME" sh -c "mkdir -p /var/lib/hermes/instance && touch $_ENTERPRISE_MARKER" >/dev/null 2>&1 || true
  # Start cloud policy sync now (the unit is ConditionPathExists-gated on the
  # marker we just wrote). Best-effort — a restart would also bring it up.
  "$RT" exec "$NAME" systemctl start hermes-config-sync.service >/dev/null 2>&1 || true
  echo "[ok] Enterprise association complete.  Restart Lumen to activate: lumen restart"
}

cmd_unpair() {
  _ensure_machine
  if ! _running; then
    echo "[x] Lumen must be running to unpair.  Start it with: lumen start"; exit 1
  fi
  "$RT" exec "$NAME" python3 -m hermes.instance unpair || { echo "[x] Unpair failed."; exit 1; }
  # Remove the pairing marker so config-sync goes inert again (community mode).
  "$RT" exec "$NAME" rm -f "$_ENTERPRISE_MARKER" >/dev/null 2>&1 || true
  echo "[ok] Instance unpaired.  Restart Lumen to revert to community edition: lumen restart"
}

cmd_status() {
  if _exists && _running; then
    echo "[ok] Lumen running at  http://localhost:$(_port)/   (open with: lumen)"
  elif _exists; then
    echo "[ ] Lumen is stopped.  Start it with: lumen"
  else
    echo "[ ] Lumen is not installed.  Install with: lumen update"
  fi
}

cmd_logs() { "$RT" logs -f "$NAME"; }

# ---- background update agent (host-side; the UI-triggered update path) -------
# The container is sandboxed and CANNOT recreate itself (touching the host podman
# would defeat the cage). So "update from the UI" works like this: the UI writes an
# "update requested" marker into the data volume; THIS loop — installed once as a
# launchd agent (macOS) / systemd --user unit or nohup (Linux) by the installer —
# notices it and runs the same `lumen update` (prune-before-pull + recreate). The
# user never opens a terminal. It also removes the marker so it runs exactly once
# per request. Nothing here is privileged beyond the podman the user already runs.
# In the daemon-owned instance dir (uid 880 can write there — same place as the
# pairing marker; the parent /var/lib/hermes is root:root 0755 and NOT writable by
# the daemon). The backend's POST /api/v1/system/update touches this exact path.
_UPDATE_FLAG="/var/lib/hermes/instance/.update-requested"
cmd_agent() {
  echo "[*] Lumen update agent running (watches for UI-triggered updates)."
  while :; do
    if _running && "$RT" exec "$NAME" test -f "$_UPDATE_FLAG" 2>/dev/null; then
      "$RT" exec "$NAME" rm -f "$_UPDATE_FLAG" 2>/dev/null || true
      echo "[*] Update requested from the UI — applying..."
      cmd_update || echo "[!] Update failed; re-request it from the UI to retry."
    fi
    sleep 20
  done
}

usage() {
  cat <<'EOF'
lumen - control your local Lumen

  lumen            open Lumen in the browser (starts it if stopped)
  lumen stop       stop Lumen
  lumen start      start Lumen without opening the browser
  lumen restart    restart Lumen
  lumen update     pull the latest version and apply it (keeps your config)
  lumen status     is it running? on which port?
  lumen logs       follow the container journal
  lumen pair <code>   associate with an enterprise tenant (same image, associate mode)
  lumen unpair        remove the enterprise association (reverts to community edition)
EOF
}

case "${1:-open}" in
  ""|open|abrir)               cmd_open ;;
  start|arranca)               cmd_start ;;
  stop|para|parar)             cmd_stop ;;
  restart|reinicia)            cmd_restart ;;
  update|actualiza|actualizar) cmd_update ;;
  agent|watch)                 cmd_agent ;;
  status|estado)               cmd_status ;;
  logs|log)                    cmd_logs ;;
  pair|vincular)               cmd_pair "${2:-}" ;;
  unpair|desvincular)          cmd_unpair ;;
  -h|--help|help|ayuda)        usage ;;
  *) echo "Unknown command: $1"; echo; usage; exit 1 ;;
esac
